#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# User: Set here the F90 compiler and options
#       Pedefined compilers: INTEL, PGF, HPUX, LAHEY
#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Pick a default compiler if not supplied
ifndef COMPILER
#COMPILER = LAHEY
#COMPILER = INTEL
#COMPILER = PGF
#COMPILER = HPUX
COMPILER = GFORTRAN
endif

FC_LAHEY   = lf95
# More aggressive for production runs:
#FOPT_LAHEY = -Cpp --pca -O
# More checking for debugging:
FOPT_LAHEY = -Cpp --chk a,e,s,u --pca --ap -O0 -g --trap --trace --chkglobal

FC_INTEL   = ifort
# More aggressive for production runs:
#FOPT_INTEL = -cpp -O -fp-model precise -pc80 -prec_div
# More checking for debugging:
FOPT_INTEL = -cpp -O0 -fp-model strict -implicitnone -ftrapuv \
              -debug all -check all -warn all -g

FC_PGF     = pgf90
# More aggressive for production runs:
FOPT_PGF   = -Mpreprocess -O -fast -pc 80 -Kieee
# More checking for debugging:
#FOPT_PGF   = -Mpreprocess -O0 -Mbounds -Mchkfpstk -Mchkptr -Mchkstk \
#             -Ktrap=fp -pc 80 -Kieee

FC_HPUX    = f90
FOPT_HPUX  = -O -u +Oall +check=on

FC_GFORTRAN     = gfortran
FOPT_GFORTRAN   = -cpp -O -g

# define FULL_ALGEBRA for non-sparse integration
FC   = $(FC_$(COMPILER))
FOPT = $(FOPT_$(COMPILER)) # -DFULL_ALGEBRA

LIBS =
#LIBS = -llapack -lblas

#############################################################################
# Test if various files are found on disk or not
# so that we can include/exclude them from the Make process
#############################################################################

# JacobianSP
HAS_JAC_SP =0
ifeq ($(shell test -f cloudchem_JacobianSP.F90 && echo y),y)
  HAS_JAC_SP =1
endif

# Jacobian
HAS_JAC = 0
ifeq ($(shell test -f cloudchem_Jacobian.F90 && echo y),y)
  HAS_JAC = 1
endif

# HessianSP
HAS_HES_SP = 0
ifeq ($(shell test -f cloudchem_HessianSP.F90 && echo y),y)
  HAS_HES_SP = 1
endif

# Hessian
HAS_HES=0
ifeq ($(shell test -f cloudchem_Hessian.F90 && echo y),y)
  HAS_HES = 1
endif

# StoichiomSP
HAS_STM_SP = 0
ifeq ($(shell test -f  cloudchem_StoichiomSP.F90 && echo y),y)
  HAS_STM_SP=1
endif

# Stoichiom
HAS_STM = 0
ifeq ($(shell test -f  cloudchem_Stoichiom.F90 && echo y),y)
  HAS_STM=1
endif

# If an external rates module has been suppllied,
# also define the correspoinding object file
ifdef EXTERNAL_RATES_F90
  EXTERNAL_RATES_OBJ := $(EXTERNAL_RATES_F90:.f90=.o)
  EXTERNAL_RATES_OBJ := $(EXTERNAL_RATES_OBJ:.F90=.o)
endif

#############################################################################
# Construct lists of objects and sources
#############################################################################

# Command to create Matlab mex gateway routines
# Note: use $(FC) as the mex Fortran compiler
MEX  = mex

# NOTE: Allow for an external module to be USE-d by F90_Rates
# by specifying the relevant environment variables.
GENSRC = cloudchem_Precision.F90  cloudchem_Parameters.F90  \
         cloudchem_Global.F90     $(EXTERNAL_RATES_F90)
GENOBJ = cloudchem_Precision.o    cloudchem_Parameters.o    \
         cloudchem_Global.o       $(EXTERNAL_RATES_OBJ)

FUNSRC = cloudchem_Function.F90
FUNOBJ = cloudchem_Function.o

JACSRC   =
JACOBJ   =
JACSPOBJ =
ifeq ($(HAS_JAC_SP),1)
  JACSRC   += cloudchem_JacobianSP.F90
  JACOBJ   += cloudchem_JacobianSP.o
  JACSPOBJ += cloudchem_JacobianSP.o
endif
ifeq ($(HAS_JAC),1)
  JACSRC   += cloudchem_Jacobian.F90
  JACOBJ   += cloudchem_Jacobian.o
endif

HESSRC   =
HESOBJ   =
HESSPOBJ =
ifeq ($(HAS_HES_SP),1)
  HESSRC   += cloudchem_HessianSP.F90
  HESOBJ   += cloudchem_HessianSP.o
  HESSPOBJ += cloudchem_HessianSP.o
endif
ifeq ($(HAS_HES),1)
  HESSRC   += cloudchem_Hessian.F90
  HESOBJ   += cloudchem_Hessian.o
endif

STMSRC   =
STMOBJ   =
STMSPOBJ =
ifeq ($(HAS_STM_SP),1)
  STMSRC   += cloudchem_StoichiomSP.F90
  STMOBJ   += cloudchem_StoichiomSP.o
  STMSPOBJ += cloudchem_StoichiomSP.o
endif
ifeq ($(HAS_HES),1)
  HESSRC   += cloudchem_Stoichiom.F90
  HESOBJ   += cloudchem_Stoichiom.o
endif

UTLSRC = cloudchem_Rates.F90 cloudchem_Util.F90 cloudchem_Monitor.F90
UTLOBJ = cloudchem_Rates.o   cloudchem_Util.o   cloudchem_Monitor.o

LASRC  = cloudchem_LinearAlgebra.F90
LAOBJ  = cloudchem_LinearAlgebra.o

STOCHSRC = cloudchem_Stochastic.F90
STOCHOBJ = cloudchem_Stochastic.o

MAINSRC = cloudchem_Main.F90       cloudchem_Initialize.F90 \
          cloudchem_Integrator.F90 cloudchem_Model.F90
MAINOBJ = cloudchem_Main.o         cloudchem_Initialize.o   \
          cloudchem_Integrator.o   cloudchem_Model.o

#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# User: modify the line below to include only the
#       objects needed by your application
#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
ALLOBJ = $(GENOBJ) $(FUNOBJ) $(JACOBJ) $(HESOBJ) $(STMOBJ) \
	 $(UTLOBJ) $(LAOBJ)

SIMPLEOBJ = $(GENOBJ) $(FUNOBJ) $(UTLOBJ) $(LAOBJ)

#############################################################################
# Makefile targets and rules
#############################################################################

#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# User: modify the line below to include only the
#       executables needed by your application
#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
all:    exe

exe:	$(ALLOBJ) $(MAINOBJ)
	$(FC) $(FOPT) $(ALLOBJ) $(MAINOBJ) $(LIBS) -o cloudchem.exe

stochastic:$(ALLOBJ) $(STOCHOBJ) $(MAINOBJ)
	$(FC) $(FOPT) $(ALLOBJ) $(STOCHOBJ) $(MAINOBJ) $(LIBS) \
	-o cloudchem_stochastic.exe

mex:    $(ALLOBJ)
	$(MEX) FC#$(FC) -fortran -O cloudchem_mex_Fun.F90     $(ALLOBJ)
	$(MEX) FC#$(FC) -fortran -O cloudchem_mex_Jac_SP.F90  $(ALLOBJ)
	$(MEX) FC#$(FC) -fortran -O cloudchem_mex_Hessian.F90 $(ALLOBJ)

clean:
	rm -f *.o *.mod \
	cloudchem*.dat cloudchem.exe cloudchem*.mexglx \
	cloudchem.log

distclean:
	rm -f *.o *.mod \
	cloudchem*.dat cloudchem*.exe cloudchem.log \
	cloudchem_*.f90 cloudchem_*.F90 cloudchem_*.mexglx \
	results*.m *.dat

cloudchem_Precision.o: cloudchem_Precision.F90
	$(FC) $(FOPT) -c $<

cloudchem_Parameters.o: cloudchem_Parameters.F90 cloudchem_Precision.o
	$(FC) $(FOPT) -c $<

cloudchem_Monitor.o: cloudchem_Monitor.F90 cloudchem_Precision.o
	$(FC) $(FOPT) -c $<

cloudchem_Global.o: cloudchem_Global.F90 cloudchem_Parameters.o cloudchem_Precision.o
	$(FC) $(FOPT) -c $<

cloudchem_Initialize.o: cloudchem_Initialize.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Function.o: cloudchem_Function.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Stochastic.o: cloudchem_Stochastic.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_JacobianSP.o: cloudchem_JacobianSP.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Jacobian.o: cloudchem_Jacobian.F90 $(GENOBJ) $(JACSPOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_LinearAlgebra.o: cloudchem_LinearAlgebra.F90 $(GENOBJ) $(JACSPOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Rates.o: cloudchem_Rates.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_HessianSP.o: cloudchem_HessianSP.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Hessian.o:  cloudchem_Hessian.F90 $(GENOBJ) $(HESSPOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_StoichiomSP.o: cloudchem_StoichiomSP.F90 $(GENOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Stoichiom.o: cloudchem_Stoichiom.F90 $(GENOBJ) $(STMSPOBJ)
	$(FC) $(FOPT) -c $<

cloudchem_Util.o: cloudchem_Util.F90 $(GENOBJ) cloudchem_Monitor.o
	$(FC) $(FOPT) -c $<

cloudchem_Main.o: cloudchem_Main.F90 $(ALLOBJ) \
                 cloudchem_Initialize.o cloudchem_Model.o cloudchem_Integrator.o
	$(FC) $(FOPT) -c $<

cloudchem_Model.o: cloudchem_Model.F90 $(ALLOBJ) cloudchem_Integrator.o
	$(FC) $(FOPT) -c $<

cloudchem_Integrator.o: cloudchem_Integrator.F90 $(ALLOBJ)
	$(FC) $(FOPT) -c $<

# Define rule for a user-defined module that gets USE-d by F90_Rates.
# This rule is only applied if both variables are not blank.
ifdef EXTERNAL_RATES_F90
ifdef EXTERNAL_RATES_OBJ
$(EXTERNAL_RATES_OBJ): $(EXTERNAL_RATES_F90) cloudchem_Precision.o cloudchem_Global.o cloudchem_Parameters.o
	$(FC) $(FOPT) -c $<
endif
endif
